# Meridian / Mars
.claude/
.codex/
.mars/
.meridian/
.meridian-prompts/
.meridian-scratch/
.meridian-export/
mars.lock
meridian.local.toml
mars.local.toml

# Node
node_modules/
dist/
*.tsbuildinfo

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/

# Runtime
tasks/
# Watch-daemon control plane: machine-local desired-state, live status, lock,
# and rerun logs — not portable source (watcher.json holds an absolute path).
control/
*.nii.gz
*.dcm

# Local scratch / throwaway
temp/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Dashboard fixtures — committed test data (the disk contract the harness
# targets). Re-include despite the broad tasks/ and *.nii.gz rules above.
!fixtures/
!fixtures/tasks/
!fixtures/**

# user settings (not committed)
labrat.config.json

# Claude Science registry bookkeeping (not part of a skill)
skills/**/.catalog_stamp
skills/**/.sync-org
# Published-paper reference figures — kept local, not redistributed (rights)
skills/**/reference_figures/
